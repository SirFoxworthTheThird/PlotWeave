ption":"Legendary free city","x":1692,"y":730.0611866005639,"createdAt":1713200000000,"updatedAt":1776277131318},{"id":"a0000000-0000-4000-a000-000000000022","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"Renere","description":"City in Vintas","x":1627,"y":528.3208897274019,"createdAt":1713200000000,"updatedAt":1776277193286},{"id":"a0000000-0000-4000-a000-000000000023","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"ADEMRE","description":"Nation","x":1722,"y":1371.931335037145,"createdAt":1713200000000,"updatedAt":1776277181363}],"characters":[{"id":"30000000-0000-4000-a000-000000000001","worldId":"10000000-0000-4000-a000-000000000000","name":"Kvothe","aliases":["Kote"],"description":"The legendary arcanist and musician, hiding as an innkeeper.","portraitImageId":null,"color":"#b91c1c","tags":["protagonist"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"30000000-0000-4000-a000-000000000002","worldId":"10000000-0000-4000-a000-000000000000","name":"Bast","aliases":[],"description":"Kvothe's Fae student.","portraitImageId":null,"color":null,"tags":["fae"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"30000000-0000-4000-a000-000000000003","worldId":"10000000-0000-4000-a000-000000000000","name":"Chronicler","aliases":["Chronicler","Devan Lochees"],"description":"A famous scribe.","portraitImageId":null,"color":null,"tags":["scribe"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"30000000-0000-4000-a000-000000000004","worldId":"10000000-0000-4000-a000-000000000000","name":"Arliden","aliases":[],"description":"Kvothe's father.","portraitImageId":null,"color":null,"tags":["parent"],"isAlive":false,"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"30000000-0000-4000-a000-000000000005","worldId":"10000000-0000-4000-a000-000000000000","name":"Laurian","aliases":[],"description":"Kvothe's mother.","portraitImageId":null,"color":null,"tags":["parent"],"isAlive":false,"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"30000000-0000-4000-a000-000000000006","worldId":"10000000-0000-4000-a000-000000000000","name":"Abenthy","aliases":["Ben"],"description":"Kvothe's first teacher.","portraitImageId":null,"color":null,"tags":["mentor"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"30000000-0000-4000-a000-000000000007","worldId":"10000000-0000-4000-a000-000000000000","name":"Denna","aliases":[],"description":"Kvothe's elusive love interest.","portraitImageId":null,"color":null,"tags":["love_interest"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"30000000-0000-4000-a000-000000000008","worldId":"10000000-0000-4000-a000-000000000000","name":"Simmon","aliases":["Sim"],"description":"Kvothe's friend.","portraitImageId":null,"color":null,"tags":["friend"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"30000000-0000-4000-a000-000000000009","worldId":"10000000-0000-4000-a000-000000000000","name":"Wilem","aliases":["Wil"],"description":"Kvothe's friend.","portraitImageId":null,"color":null,"tags":["friend"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"30000000-0000-4000-a000-000000000010","worldId":"10000000-0000-4000-a000-000000000000","name":"Ambrose Jakis","aliases":[],"description":"Kvothe's rival.","portraitImageId":null,"color":null,"tags":["antagonist"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"30000000-0000-4000-a000-000000000019","worldId":"10000000-0000-4000-a000-000000000000","name":"Cinder","aliases":[],"description":"One of the Chandrian.","portraitImageId":null,"color":"#000000","tags":["chandrian"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"30000000-0000-4000-a000-000000000020","worldId":"10000000-0000-4000-a000-000000000000","name":"Haliax","aliases":["Lanre"],"description":"Leader of the Chandrian.","portraitImageId":null,"color":"#000000","tags":["chandrian"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"b1e30133-29d0-4f94-8f70-e33df9d9f312","worldId":"10000000-0000-4000-a000-000000000000","name":"Devi","aliases":[],"description":"Female gaelet operating out of Imre. Loans money to University students at high interest, holding their blood as collateral. Dangerous and shrewd. Lends Kvothe money when he is desperate. Has more secrets than she reveals.","portraitImageId":null,"color":null,"tags":["gaelet","imre","moneylender"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"d3763704-c74f-431b-9045-8e415d8029d0","worldId":"10000000-0000-4000-a000-000000000000","name":"Elodin","aliases":["Master Elodin"],"description":"Master Namer at the University. Eccentric and seemingly mad, but extraordinarily powerful. Spent time in the Rookery (University asylum). Recognises Kvothe's potential as a Namer.","portraitImageId":null,"color":null,"tags":["master","namer","university"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"de769a56-8aa4-4235-9a5c-fb52cf75bef7","worldId":"10000000-0000-4000-a000-000000000000","name":"Hemme","aliases":["Master Hemme"],"description":"Master Rhetorician at the University. Openly hostile to Kvothe from their first meeting. Attempts to have Kvothe whipped after a public humiliation. Antagonistic presence throughout Kvothe's first terms.","portraitImageId":null,"color":null,"tags":["master","rhetorician","university","antagonist"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"ebcb2993-4269-4167-9fea-3bfc47935cba","worldId":"10000000-0000-4000-a000-000000000000","name":"Kilvin","aliases":["Master Kilvin"],"description":"Master Artificer at the University. Large, foreign-born man from Ceald who speaks broken Aturan. Passionate about artificing and has great respect for Kvothe's talent. Oversees the Artificery workshop.","portraitImageId":null,"color":null,"tags":["master","artificer","university"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1713200000000}],"items":[{"id":"40000000-0000-4000-a000-000000000001","worldId":"10000000-0000-4000-a000-000000000000","name":"Kvothe's First Lute","description":"Destroyed by Ambrose.","iconType":"artifact","imageId":null,"tags":["music"]},{"id":"59ef6382-ce54-43d7-a8c1-e029c65df874","worldId":"10000000-0000-4000-a000-000000000000","name":"Kvothe's Lute (Second)","description":"A superior lute Kvothe acquires after his first is destroyed by one of Ambrose's servants. He earns money busking and pawns it to afford University tuition, but redeems it.","iconType":"other","imageId":null,"tags":["music","lute"]},{"id":"81c2ef7b-9a7c-4e85-88bd-9d9b57437937","worldId":"10000000-0000-4000-a000-000000000000","name":"The Bloodless","description":"A sympathy lamp Kvothe builds as his Artificery masterwork under Kilvin. Called 'bloodless' because it draws no blood from its user. Demonstrates Kvothe's exceptional talent in artificing.","iconType":"artifact","imageId":null,"tags":["sympathy","artificery","masterwork"]},{"id":"dc4b0653-488a-4f7c-a171-1a43e6acbb05","worldId":"10000000-0000-4000-a000-000000000000","name":"Underthing Key","description":"A key Kvothe obtains granting access to the Underthing — the forgotten passages and rooms beneath the University. Only a handful of students know of its existence.","iconType":"key","imageId":null,"tags":["university","underthing"]}],"characterSnapshots":[{"currentLocationMarkerId":null,"currentMapLayerId":null,"inventoryItemIds":[],"inventoryNotes":"","travelModeId":null,"sortKey":null,"createdAt":1713200000000,"updatedAt":1713200000000,"id":"0df05791-91f8-48f0-81ec-8591ce7b0770","worldId":"10000000-0000-4000-a000-000000000000","characterId":"30000000-0000-4000-a000-000000000001","eventId":"70000000-0000-4000-a000-000000000021","isAlive":true,"statusNotes":"Kvothe survives on the streets of Tarbean, begging, stealing, and sleeping rough for nearly three years, numbed by grief and detached from his former self."},{"currentLocationMarkerId":null,"currentMapLayerId":null,"inventoryItemIds":[],"inventoryNotes":"","travelModeId":null,"sortKey":null,"createdAt":1713200000000,"updatedAt":1713200000000,"id":"2bfed18b-86c9-4d97-9e67-dfc0d700c8a0","worldId":"10000000-0000-4000-a000-000000000000","characterId":"30000000-0000-4000-a000-000000000007","eventId":"70000000-0000-4000-a000-000000000056","isAlive":true,"statusNotes":"Denna is found near Trebon, having been drugged with Denner resin. She and Kvothe are briefly reunited amid the chaos surrounding the draccus."},{"currentLocationMarkerId":null,"currentMapLayerId":null,"inventoryItemIds":[],"inventoryNotes":"","travelModeId":null,"sortKey":null,"createdAt":1713200000000,"updatedAt":1713200000000,"id":"442b235e-3617-4ab8-98fd-0e67fafce8ed","worldId":"10000000-0000-4000-a000-000000000000","characterId":"30000000-0000-4000-a000-000000000001","eventId":"70000000-0000-4000-a000-000000000031","isAlive":true,"statusNotes":"Kvothe is admitted to the University at an exceptionally young age, assessed a term-fee of three talents — far lower than expected, reflecting his remarkable performance before the masters."},{"currentLocationMarkerId":null,"currentMapLayerId":null,"inventoryItemIds":[],"inventoryNotes":"","travelModeId":null,"sortKey":null,"createdAt":1713200000000,"updatedAt":1713200000000,"id":"487b84bb-1747-464c-b7d9-b07194178412","worldId":"10000000-0000-4000-a000-000000000000","characterId":"30000000-0000-4000-a000-000000000001","eventId":"70000000-0000-4000-a000-000000000028","isAlive":true,"statusNotes":"Kvothe meets Denna on the road to Anilin and is immediately captivated. The encounter is brief but leaves a lasting impression on him."},{"currentLocationMarkerId":null,"currentMapLayerId":null,"inventoryItemIds":[],"inventoryNotes":"","travelModeId":null,"sortKey":null,"createdAt":1713200000000,"updatedAt":1713200000000,"id":"50fedb76-e805-40fb-ae7e-b44112e341f3","worldId":"10000000-0000-4000-a000-000000000000","characterId":"30000000-0000-4000-a000-000000000008","eventId":"70000000-0000-4000-a000-000000000031","isAlive":true,"statusNotes":"Simmon is present at the University during Kvothe's admission, beginning the friendship that will define much of Kvothe's time there."},{"currentLocationMarkerId":null,"currentMapLayerId":null,"inventoryItemIds":[],"inventoryNotes":"","travelModeId":null,"sortKey":null,"createdAt":1713200000000,"updatedAt":1713200000000,"id":"5176567b-61e3-4459-a9eb-c2ebefa189b1","worldId":"10000000-0000-4000-a000-000000000000","characterId":"30000000-0000-4000-a000-000000000009","eventId":"70000000-0000-4000-a000-000000000031","isAlive":true,"statusNotes":"Wilem is present at the University during Kvothe's admission, becoming one of his earliest and steadiest companions."},{"currentLocationMarkerId":null,"currentMapLayerId":null,"inventoryItemIds":[],"inventoryNotes":"","travelModeId":null,"sortKey":null,"createdAt":1713200000000,"updatedAt":1713200000000,"id":"57a55d64-5f70-4dcb-a28c-0e8efba08996","worldId":"10000000-0000-4000-a000-000000000000","characterId":"30000000-0000-4000-a000-000000000007","eventId":"70000000-0000-4000-a000-000000000028","isAlive":true,"statusNotes":"Denna meets Kvothe on the road, trading stories before they part ways. She is travelling alone and elusive about her destination."},{"currentLocationMarkerId":null,"currentMapLayerId":null,"inventoryItemIds":[],"inventoryNotes":"","travelModeId":null,"sortKey":null,"createdAt":1713200000000,"updatedAt":1713200000000,"id":"989b9c8e-f31d-444d-ba34-66fb6cd4b945","worldId":"10000000-0000-4000-a000-000000000000","characterId":"30000000-0000-4000-a000-000000000001","eventId":"70000000-0000-4000-a000-000000000016","isAlive":true,"statusNotes":"Kvothe was away from camp when the Chandrian struck. He returns to find his entire troupe slaughtered, his parents among the dead, and is paralysed with horror and grief."},{"currentLocationMarkerId":null,"currentMapLayerId":null,"inventoryItemIds":[],"inventoryNotes":"","travelModeId":null,"sortKey":null,"createdAt":1713200000000,"updatedAt":1713200000000,"id":"afd3eb36-158e-4fb6-be6a-4e22333cf05f","worldId":"10000000-0000-4000-a000-000000000000","characterId":"30000000-0000-4000-a000-000000000005","eventId":"70000000-0000-4000-a000-000000000016","isAlive":false,"statusNotes":"Killed by the Chandrian alongside Arliden and the rest of the Edema Ruh troupe."},{"currentLocationMarkerId":null,"currentMapLayerId":null,"inventoryItemIds":[],"inventoryNotes":"","travelModeId":null,"sortKey":null,"createdAt":1713200000000,"updatedAt":1713200000000,"id":"b92262f0-f9db-4b59-98b1-bb58b098bbf3","worldId":"10000000-0000-4000-a000-000000000000","characterId":"30000000-0000-4000-a000-000000000001","eventId":"70000000-0000-4000-a000-000000000056","isAlive":true,"statusNotes":"Kvothe is investigating Chandrian signs near Trebon when he encounters a draccus maddened by Denner resin. He must find a way to stop it before it destroys the town."},{"currentLocationMarkerId":null,"currentMapLayerId":null,"inventoryItemIds":[],"inventoryNotes":"","travelModeId":null,"sortKey":null,"createdAt":1713200000000,"updatedAt":1713200000000,"id":"fa5844d1-4488-4272-84ee-6b6a22867470","worldId":"10000000-0000-4000-a000-000000000000","characterId":"30000000-0000-4000-a000-000000000004","eventId":"70000000-0000-4000-a000-000000000016","isAlive":false,"statusNotes":"Killed by the Chandrian during the massacre of Kvothe's troupe. His song researching the Chandrian drew their lethal attention."}],"characterMovements":[],"itemPlacements":[],"locationSnapshots":[],"itemSnapshots":[],"relationships":[{"id":"074ea5cb-85f8-4ffa-aaa9-602944fefcc5","worldId":"10000000-0000-4000-a000-000000000000","characterAId":"30000000-0000-4000-a000-000000000001","characterBId":"d3763704-c74f-431b-9045-8e415d8029d0","label":"master-student","strength":"moderate","sentiment":"complex","description":"Elodin recognises Kvothe as a potential Namer. Their relationship is erratic — Elodin's teaching methods are unconventional and often seem like avoidance.","isBidirectional":false,"startEventId":null,"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"2701478e-099a-4d2b-aff3-3bd1424c0b35","worldId":"10000000-0000-4000-a000-000000000000","characterAId":"30000000-0000-4000-a000-000000000001","characterBId":"ebcb2993-4269-4167-9fea-3bfc47935cba","label":"mentor","strength":"strong","sentiment":"positive","description":"Kilvin is Kvothe's master in the Artificery and holds him in high regard. Kvothe earns his RE'LAR rank partly through Kilvin's recognition of his talent.","isBidirectional":true,"startEventId":null,"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"50000000-0000-4000-a000-000000000001","worldId":"10000000-0000-4000-a000-000000000000","characterAId":"30000000-0000-4000-a000-000000000001","characterBId":"30000000-0000-4000-a000-000000000002","label":"Master/Student","strength":"bond","sentiment":"positive","description":"Kvothe is teaching Bast.","isBidirectional":true,"startEventId":null,"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"50000000-0000-4000-a000-000000000002","worldId":"10000000-0000-4000-a000-000000000000","characterAId":"30000000-0000-4000-a000-000000000001","characterBId":"30000000-0000-4000-a000-000000000007","label":"Love Interest","strength":"strong","sentiment":"complex","description":"Profound spark but secretive.","isBidirectional":true,"startEventId":"70000000-0000-4000-a000-000000000028","createdAt":1713200000000,"updatedAt":1713200000000},{"id":"50000000-0000-4000-a000-000000000003","worldId":"10000000-0000-4000-a000-000000000000","characterAId":"30000000-0000-4000-a000-000000000001","characterBId":"30000000-0000-4000-a000-000000000010","label":"Rival","strength":"strong","sentiment":"negative","description":"Bitter enemies.","isBidirectional":true,"startEv