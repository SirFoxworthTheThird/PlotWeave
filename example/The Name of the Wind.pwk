{"version":7,"type":"data","exportedAt":1776284698287,"world":{"id":"10000000-0000-4000-a000-000000000000","name":"The Name of the Wind","description":"The autobiography of Kvothe, told over three days to Chronicler at the Waystone Inn.","coverImageId":null,"createdAt":1713200000000,"updatedAt":1713200000000,"continuityStaleThreshold":5},"mapLayers":[{"id":"yF9kfivU4hqYe27Nv3zMj","worldId":"10000000-0000-4000-a000-000000000000","parentMapId":null,"name":"Temerant","description":"","imageId":"KJ4_fsU7KYUd0q363J7oA","imageWidth":2048,"imageHeight":1536,"scalePixelsPerUnit":null,"scaleUnit":null,"createdAt":1776264719962,"updatedAt":1776264719962}],"locationMarkers":[{"id":"a0000000-0000-4000-a000-000000000001","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"Ralien","description":"City in Ceald","x":462,"y":1037.8225588583646,"createdAt":1713200000000,"updatedAt":1776277208515},{"id":"a0000000-0000-4000-a000-000000000002","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"CEALD","description":"Nation","x":559,"y":976.70970357288,"createdAt":1713200000000,"updatedAt":1776276798809},{"id":"a0000000-0000-4000-a000-000000000003","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"THE ATURAN EMPIRE","description":"Nation","x":1072,"y":964.7178617862885,"createdAt":1713200000000,"updatedAt":1776276828608},{"id":"a0000000-0000-4000-a000-000000000004","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"Atur","description":"Capital of the Aturan Empire","x":1146,"y":825.900741736863,"createdAt":1713200000000,"updatedAt":1776276820651},{"id":"a0000000-0000-4000-a000-000000000005","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"Cershaen","description":"City in Modeg","x":1483,"y":1091.7899260047304,"createdAt":1713200000000,"updatedAt":1776277187728},{"id":"a0000000-0000-4000-a000-000000000006","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"MODEG","description":"Nation","x":1400,"y":550,"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"a0000000-0000-4000-a000-000000000007","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"COMMONWEALTH","description":"Nation","x":300,"y":750,"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"a0000000-0000-4000-a000-000000000008","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"Anilin","description":"City","x":823,"y":723.0387515136905,"createdAt":1713200000000,"updatedAt":1776277214544},{"id":"a0000000-0000-4000-a000-000000000009","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"THE GREAT STONE ROAD","description":"Major trade route","x":1000,"y":750,"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"a0000000-0000-4000-a000-000000000010","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"THE ELD","description":"Vast ancient forest","x":1300,"y":750,"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"a0000000-0000-4000-a000-000000000011","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"The University","description":"Center of arcane learning","x":625,"y":637.1652038215226,"createdAt":1713200000000,"updatedAt":1776276786864},{"id":"a0000000-0000-4000-a000-000000000012","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"Imre","description":"City of music and arts","x":643,"y":630.1699627793442,"createdAt":1713200000000,"updatedAt":1776276783529},{"id":"a0000000-0000-4000-a000-000000000013","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"Tarbean","description":"Large divided city","x":603,"y":579.2522247645468,"createdAt":1713200000000,"updatedAt":1776276790474},{"id":"a0000000-0000-4000-a000-000000000014","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"THE REFT","description":"Region","x":532,"y":512.33176734528,"createdAt":1713200000000,"updatedAt":1776276796035},{"id":"a0000000-0000-4000-a000-000000000015","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"Hallowfell","description":"City","x":261,"y":531.3324471963973,"createdAt":1713200000000,"updatedAt":1776276803870},{"id":"a0000000-0000-4000-a000-000000000016","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"YLL","description":"Island Nation","x":526,"y":162.2862173204157,"createdAt":1713200000000,"updatedAt":1776277250709},{"id":"a0000000-0000-4000-a000-000000000017","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"THE CENTHE SEA","description":"Body of water","x":946,"y":262.1584053103488,"createdAt":1713200000000,"updatedAt":1776277225375},{"id":"a0000000-0000-4000-a000-000000000018","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"THE SMALL KINGDOMS","description":"Region","x":1275,"y":540.3127315139934,"createdAt":1713200000000,"updatedAt":1776277161384},{"id":"a0000000-0000-4000-a000-000000000019","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"Junpui","description":"City","x":1139,"y":342.1210134988931,"createdAt":1713200000000,"updatedAt":1776277235839},{"id":"a0000000-0000-4000-a000-000000000020","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"VINTAS","description":"Nation","x":1703,"y":441.04555002486427,"createdAt":1713200000000,"updatedAt":1776276835349},{"id":"a0000000-0000-4000-a000-000000000021","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"The Free City of Tinue","description":"Legendary free city","x":1692,"y":730.0611866005639,"createdAt":1713200000000,"updatedAt":1776277131318},{"id":"a0000000-0000-4000-a000-000000000022","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"Renere","description":"City in Vintas","x":1627,"y":528.3208897274019,"createdAt":1713200000000,"updatedAt":1776277193286},{"id":"a0000000-0000-4000-a000-000000000023","worldId":"10000000-0000-4000-a000-000000000000","mapLayerId":"yF9kfivU4hqYe27Nv3zMj","name":"ADEMRE","description":"Nation","x":1722,"y":1371.931335037145,"createdAt":1713200000000,"updatedAt":1776277181363}],"characters":[{"id":"30000000-0000-4000-a000-000000000001","worldId":"10000000-0000-4000-a000-000000000000","name":"Kvothe","aliases":["Kote"],"description":"The legendary arcanist, musician, and thief — known throughout the world by a dozen names. As a child he traveled with his father's Edema Ruh troupe before the Chandrian murdered his family. He spent three years as a street urchin in Tarbean before entering the University at an unheard-of young age, where he became both celebrated and notorious. In the present day he hides under the name Kote, running a quiet inn and pretending to be nobody.","portraitImageId":"EwQYzAtP8MCzVjM_AVW4n","color":"#b91c1c","tags":["protagonist"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1776284151431},{"id":"30000000-0000-4000-a000-000000000002","worldId":"10000000-0000-4000-a000-000000000000","name":"Bast","aliases":[],"description":"Kvothe's student and companion at the Waystone Inn — seemingly human, but in truth a Fae noble of royal blood. Bast is quick-witted, charming, and occasionally ruthless when his master's welfare is at stake. He serves with absolute devotion, though he chafes at Kvothe's deliberate suppression of his own legend.","portraitImageId":"UnjGQzV34BB_gbalMtKzx","color":null,"tags":["fae"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1776283531761},{"id":"30000000-0000-4000-a000-000000000003","worldId":"10000000-0000-4000-a000-000000000000","name":"Chronicler","aliases":["Chronicler","Devan Lochees"],"description":"Devan Lochees, called Chronicler — the most respected scribe in the known world. He travels to the Waystone Inn to record Kvothe's story firsthand, having tracked the legendary figure for years. Practical, skeptical, and precise, Chronicler is shaken when legend and reality collide.","portraitImageId":"7dQF1340neJ7FACIwc1av","color":null,"tags":["scribe"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1776283687140},{"id":"30000000-0000-4000-a000-000000000004","worldId":"10000000-0000-4000-a000-000000000000","name":"Arliden","aliases":[],"description":"Kvothe's father and leader of the Edema Ruh troupe — a celebrated performer and composer. Arliden was working on a song about the Chandrian at the time of his death, a project born of scholarly curiosity that ultimately drew the demons to his family. His talent, warmth, and love of craft shaped everything Kvothe became.","portraitImageId":"ssdnnG93jmvorlhMupG12","color":null,"tags":["parent"],"isAlive":false,"createdAt":1713200000000,"updatedAt":1776283476359},{"id":"30000000-0000-4000-a000-000000000005","worldId":"10000000-0000-4000-a000-000000000000","name":"Laurian","aliases":[],"description":"Kvothe's mother, known as Laurian — born a woman of noble family who left that life to marry Arliden and travel with the Ruh. She was a rare talent: poet, performer, and fiercely intelligent. She died in the Chandrian massacre along with her husband.","portraitImageId":"daQgF9OIqf_tlMp74HAwU","color":null,"tags":["parent"],"isAlive":false,"createdAt":1713200000000,"updatedAt":1776284211457},{"id":"30000000-0000-4000-a000-000000000006","worldId":"10000000-0000-4000-a000-000000000000","name":"Abenthy","aliases":["Ben"],"description":"Called Ben by the troupe — a former University-trained arcanist who gave up academic life to wander. He joined Arliden's troupe for a time and became Kvothe's first real teacher, introducing him to sympathy, the Alar, and the fundamentals of naming. His departure left Kvothe without formal guidance at a crucial age.","portraitImageId":"KLtifaWmrT_HjK5tqyktk","color":null,"tags":["mentor"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1776283358287},{"id":"30000000-0000-4000-a000-000000000007","worldId":"10000000-0000-4000-a000-000000000000","name":"Denna","aliases":[],"description":"A beautiful, elusive young woman who keeps few fixed relationships and no fixed address. Denna's past is obscure and her present is full of contradictions — she has a secret patron known only as Master Ash who funds her studies, and her path seems to cross the Chandrian's as often as Kvothe's does. She and Kvothe are drawn to each other but always slightly out of step.","portraitImageId":"YAqIcVS6aMVCc0OF9jOlU","color":null,"tags":["love_interest"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1776283810375},{"id":"30000000-0000-4000-a000-000000000008","worldId":"10000000-0000-4000-a000-000000000000","name":"Simmon","aliases":["Sim"],"description":"A cheerful, warm-hearted student at the University from a noble Aturan family. Simmon is a talented poet and one of Kvothe's most loyal friends. He is perceptive about people despite an often breezy manner, and his steady companionship helps Kvothe stay sane through the pressures of University life.","portraitImageId":"Yj6b7jE94RvOH7PcE3vmZ","color":null,"tags":["friend"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1776284259509},{"id":"30000000-0000-4000-a000-000000000009","worldId":"10000000-0000-4000-a000-000000000000","name":"Wilem","aliases":["Wil"],"description":"A Cealdish student at the University, reserved and fiercely logical. Wilem comes from a modest background and has little patience for pretension. He is one of Kvothe's earliest and most dependable friends — honest to a fault, unimpressed by reputation, and quietly brave.","portraitImageId":"pBP3qwOo-z_xZ5BVHLnSh","color":null,"tags":["friend"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1776284303146},{"id":"30000000-0000-4000-a000-000000000010","worldId":"10000000-0000-4000-a000-000000000000","name":"Ambrose Jakis","aliases":[],"description":"Ambrose Jakis — arrogant, wealthy, and well-connected. The son of a powerful Aturan baron, Ambrose is used to getting what he wants, and he takes an immediate and lasting dislike to Kvothe. Their rivalry is one of the defining conflicts of Kvothe's time at the University, escalating from petty antagonism to genuine danger.","portraitImageId":"rLDKWKJP_RGkR4eIV4xdm","color":null,"tags":["antagonist"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1776283421555},{"id":"30000000-0000-4000-a000-000000000019","worldId":"10000000-0000-4000-a000-000000000000","name":"Cinder","aliases":[],"description":"One of the Chandrian — a creature of myth made terrifyingly real. He appears as a man with white hair and black eyes that shift like winter storms. It was Cinder who taunted young Kvothe at the massacre site. Kvothe burns with hatred and grief at the sound of his name.","portraitImageId":"JcctoFBt4_XDV9RpXewso","color":"#000000","tags":["chandrian"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1776283746339},{"id":"30000000-0000-4000-a000-000000000020","worldId":"10000000-0000-4000-a000-000000000000","name":"Haliax","aliases":["Lanre"],"description":"The leader of the Chandrian, formerly known as Lanre — a once-legendary hero who was broken by grief and became something monstrous. Haliax commands the group and seems to be bound by ancient restraints that even his power cannot fully break. His true nature and motivations are wrapped in layer upon layer of distorted legend.","portraitImageId":"hHIdW29GKlmKI5hrq8vNi","color":"#000000","tags":["chandrian"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1776283982635},{"id":"b1e30133-29d0-4f94-8f70-e33df9d9f312","worldId":"10000000-0000-4000-a000-000000000000","name":"Devi","aliases":[],"description":"A former student expelled from the University who now operates as a gaelet — a money-lender — in Imre. Devi is brilliant, dangerous, and meticulous. She charges reasonable interest on loans but takes blood as collateral, giving her a powerful hold over her debtors. She has a complicated, almost respectful relationship with Kvothe.","portraitImageId":"mbAQhZ7z4lJp8PaDpotLR","color":null,"tags":["gaelet","imre","moneylender"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1776283859216},{"id":"d3763704-c74f-431b-9045-8e415d8029d0","worldId":"10000000-0000-4000-a000-000000000000","name":"Elodin","aliases":["Master Elodin"],"description":"Master Namer and Re'lar instructor at the University — and quite possibly the most powerful arcanist alive. Elodin is unpredictable, enigmatic, and seemingly unhinged, but every apparent eccentricity conceals a deeper method. He spent time in the Rookery (the University's asylum) and emerged unchanged — or perhaps more himself than before. He reluctantly takes Kvothe as a student.","portraitImageId":"WvvFOoQQcMw484XV2HvJw","color":null,"tags":["master","namer","university"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1776283930261},{"id":"de769a56-8aa4-4235-9a5c-fb52cf75bef7","worldId":"10000000-0000-4000-a000-000000000000","name":"Hemme","aliases":["Master Hemme"],"description":"Master Hemme — a University instructor who teaches basic sympathy. He is petty, politically astute, and quick to punish students who embarrass him. His hostility toward Kvothe begins at their first meeting and never abates. He is the main force behind bringing Kvothe \"On the Horns\" before the masters.","portraitImageId":"Vx9XJWXp2LLUmybYvodq6","color":null,"tags":["master","rhetorician","university","antagonist"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1776284025149},{"id":"ebcb2993-4269-4167-9fea-3bfc47935cba","worldId":"10000000-0000-4000-a000-000000000000","name":"Kilvin","aliases":["Master Kilvin"],"description":"Master Kilvin — a powerfully built Cealdish man who runs the Artificery (the Fishery). He speaks in vivid, occasionally mangled Aturan and has a genuine, generous respect for exceptional craftsmanship. He is one of the few masters who is straightforwardly kind to Kvothe, valuing skill over politics.","portraitImageId":"g05HE-a64WXlhZFCUmfIK","color":null,"tags":["master","artificer","university"],"isAlive":true,"createdAt":1713200000000,"updatedAt":1776284080716}],"items":[{"id":"26ea62ce-f1dc-452b-a6f5-0ba379587349","worldId":"10000000-0000-4000-a000-000000000000","name":"The Gram","description":"A small iron disk inscribed with careful sympathy-bindings. Kvothe creates this gram to protect himself against the drain that comes from maintaining his Alar under attack — it acts as a buffer against sympathy used offensively against him.","imageId":null,"tags":["magical","crafted"],"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"40000000-0000-4000-a000-000000000001","worldId":"10000000-0000-4000-a000-000000000000","name":"Kvothe's Lute","description":"The lute Kvothe carries from his days with the Edema Ruh troupe. A fine instrument, carefully maintained through years of poverty and hardship. Destroyed by Ambrose Jakis.","iconType":"artifact","imageId":null,"tags":["music"]},{"id":"59ef6382-ce54-43d7-a8c1-e029c65df874","worldId":"10000000-0000-4000-a000-000000000000","name":"Kvothe's Lute (Second)","description":"A superior lute Kvothe acquires after his first is destroyed by Ambrose — funded through a loan from Devi. It becomes his primary instrument for his remaining time at the University.","iconType":"other","imageId":null,"tags":["music","lute"]},{"id":"626b7ac3-e232-4f66-b91a-5ea20a8574e5","worldId":"10000000-0000-4000-a000-000000000000","name":"Talent Pipes","description":"The carved ivory pipes given to musicians who pass the Eolian's performance test — proof of genuine mastery. Kvothe earns his at the Eolian in Imre, playing despite a broken string, leaving the audience speechless.","imageId":null,"tags":["musical","prestige"],"createdAt":1713200000000,"updatedAt":1713200000000},{"id":"81c2ef7b-9a7c-4e85-88bd-9d9b57437937","worldId":"10000000-0000-4000-a000-000000000000","name":"The Bloodless","description":"Kvothe's Artificery masterwork — a sympathy lamp so perfectly constructed that it gives light without consuming its wick or fuel. Its creation earns him the title Re'lar and the respect of Master Kilvin.","iconType":"artifact","imageId":null,"tags":["sympathy","artificery","masterwork"]},{"id":"dc4b0653-488a-4f7c-a171-1a43e6acbb05","worldId":"10000000-0000-4000-a000-000000000000","name":"Underthing Key","description":"A key that grants access to the Underthing — the maze of tunnels and forgotten passages beneath the University. Kvothe obtains it through his friendship with the peculiar Puppet.","iconType":"key","imageId":null,"tags":["university","underthing"]}],"characterSnapshots":[{"id":"0335d950-9414-475f-a985-0e7808ce35b8","worldId":"10000000-0000-4000-a000-000000000000","characterId":"30000000-0000-4000-a000-000000000001","eventId":"70000000-0000-4000-a000-000000000084","isAlive":true,"currentLocationMarkerId":"a0000000-0000-4000-a000-000000000012","currentMapLayerId":"yF9kfivU4hqYe27Nv3zMj","inventoryItemIds":[],"inventoryNotes":"","travelModeId":null,"sortKey":84.000084,"statusNotes":"Kvothe encounters trouble in Imre, straining his relationships there.","createdAt":1713200000000,"updatedAt":1713200000000},{"id":"0b5485f1-df9e-498c-9c03-8ad732af266b","worldId":"10000000-0000-4000-a000-000000000000","characterId":"30000000-0000-4000-a000-000000000001","eventId":"70000000-0000-4000-a000-000000000000","isAlive":true,"currentLocationMarkerId":"a0000000-0000-4000-a000-000000000007","currentMapLayerId":"yF9kfivU4hqYe27Nv3zMj","inventoryItemIds":[],"inventoryNotes":"","travelModeId":null,"sortKey":0,"statusNotes":"Kvothe tends the Waystone Inn under the name Kote, keeping his past hidden.","createdAt":1713200000000,"updatedAt":1713200000000},{"currentLocationMarkerId":"a0000000-0000-4000-a000-000000000013","currentMapLayerId":"yF9kfivU4hqYe27Nv3zMj","inventoryItemIds":[],"inventoryNotes":"","travelModeId":null,"sortKey":21.000021,"createdAt":1713200000000,"updatedAt":1713200000000,"id":"0df05791-91f8-48f0-81ec-8591ce7b0770","worldId":"10000000-0000-4000-a000-000000000000","characterId":"30000000-0000-4000-a000-000000000001","eventId":"70000000-0000-4000-a000-000000000021","isAlive":true,"statusNotes":"Kvothe survives on the streets of Tarbean, begging, stealing, and sleeping rough for nearly three years, numbed by grief and detached from his former self."},{"id":"10f1eb0c-10b8-4f70-af7c-2e638852e2f4","worldId":"10000000-0000-4000-a000-000000000000","characterId":"d3763704-c74f-431b-9045-8e415d8029d0","eventId":"70000000-0000-4000-a000-000000000082","isAlive":true,"currentLocationMarkerId":"a0000000-0000-4000-a000-000000000011","currentMapLayerId":"yF9kfivU4hqYe27Nv3zMj","inventoryItemIds":[],"inventoryNotes":"","travelModeId":null,"sortKey":82.000082,"statusNotes":"Elodin continues his unorthodox Naming instruction, pushing Kvothe toward understanding.","createdAt":1713200000000,"updatedAt":1713200000000},{"id":"110de20d-bf84-4d1d-b3e1-5fb0261acfe8","worldId":"10000000-0000-4000-a000-000000000000","characterId":"30000000-0000-4000-a000-000000000001","eventId":"70000000-0000-4000-a000-000000000029","isAlive":true,"currentLocationMarkerId":"a0000000-0000-4000-a000-000000000009","currentMapLayerId":"yF9kfivU4hqYe27Nv3zMj","inventoryItemIds":[],"inventoryNotes":"","travelModeId":null,"sortKey":29.000029,"statusNotes":"Kvothe travels the Great Stone Road toward the University after meeting Denna.","createdAt":1713200000000,"updatedAt":1713200000000},{"id":"115317b1-ec85-4f17-bfd1-6dae375ae5bd","worldId":"10000000-0000-4000-a000-000000000000","characterId":"30000000-0000-4000-a000-000000000001","eventId":"7000000