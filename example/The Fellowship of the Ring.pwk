P","name":"Barrow-wight","portraitImageId":"3eXIjwrujsSsVdj72A4V-","aliases":["Wight"],"description":"An evil spirit inhabiting the ancient burial mounds of the Barrow-downs.","tags":["Spirit","Enemy"],"relationshipIds":["rel_wight_hobbits"],"isAlive":true,"createdAt":1741000000000,"updatedAt":1775102915877,"color":null},{"id":"char_bill_pony","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Bill the Pony","aliases":["Bill"],"description":"A half-starved pony purchased from Bill Ferny in Bree. Nursed back to health by Sam, he serves as the Fellowship's loyal baggage animal.","tags":["Animal","Companion"],"isAlive":true,"relationshipIds":["rel_sam_bill"],"portraitImageId":"k9jHT9xibObv-0jsQR9GV","updatedAt":1775157266529,"color":null,"createdAt":1700000000000},{"id":"char_black_rider_1","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Black Rider","portraitImageId":"bvo1Gbm_DdUbjgMhy6efg","aliases":["Nazgûl","Ringwraith"],"description":"A dark servant of Sauron searching for the One Ring.","tags":["Nazgûl","Enemy"],"relationshipIds":["rel_frodo_blackrider"],"isAlive":true,"createdAt":1741000000000,"updatedAt":1775590611421,"color":"#ff3838"},{"id":"char_boromir","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Boromir","aliases":["Captain of the White Tower"],"description":"The eldest son of Denethor II, Steward of Gondor. A proud and valiant warrior seeking a way to save his people.","tags":["Man","Warrior","Gondor"],"isAlive":false,"relationshipIds":["rel_aragorn_boromir"],"portraitImageId":"dlesf6BfeTxIyx7_bI1W0","updatedAt":1775156893490,"color":null,"createdAt":1700000000000},{"id":"char_cave_troll","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Cave-troll","aliases":[],"description":"A massive, scaled troll that breaches the Chamber of Mazarbul during the Orc ambush.","tags":["Monster","Enemy"],"isAlive":false,"relationshipIds":[],"portraitImageId":"hvE0nPXphaWcNqhKzylr6","updatedAt":1775159493012,"color":null,"createdAt":1700000000000},{"id":"char_celeborn","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Celeborn","aliases":["Lord of Lórien"],"description":"The Lord of Lothlórien and husband to Galadriel. Known as Celeborn the Wise.","tags":["Elf","Lord"],"isAlive":true,"relationshipIds":["rel_celeborn_galadriel"],"portraitImageId":"5T_e1L_KpOTMBonXNDkaM","updatedAt":1775160297346,"color":null,"createdAt":1700000000000},{"id":"char_elrond","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Elrond Half-elven","aliases":["Master of Rivendell"],"description":"The wise and powerful Lord of Rivendell, a renowned healer and lore-master.","tags":["Elf","Lord","Healer"],"isAlive":true,"relationshipIds":["rel_elrond_frodo"],"portraitImageId":"S-yKbkRnodWpiocnrW1tI","updatedAt":1775156550028,"color":null,"createdAt":1700000000000},{"id":"char_farmer_maggot","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Farmer Maggot","portraitImageId":"nNGRKFws4VYEPXYIXPsLW","aliases":[],"description":"A stout, no-nonsense Hobbit farmer who lives in the Marish.","tags":["Hobbit","Farmer"],"relationshipIds":["rel_frodo_maggot"],"isAlive":true,"createdAt":1741000000000,"updatedAt":1775101303454,"color":null},{"id":"char_fatty_bolger","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Fredegar Bolger","portraitImageId":"RnPVKD2rwyVUHmKx4Hinp","aliases":["Fatty"],"description":"A Hobbit of Buckland and close friend of Frodo.","tags":["Hobbit"],"relationshipIds":["rel_frodo_fatty"],"isAlive":true,"createdAt":1741000000000,"updatedAt":1775101846025,"color":null},{"id":"char_galadriel","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Galadriel","aliases":["Lady of the Wood","Lady of Light"],"description":"The co-ruler of Lothlórien, one of the greatest of the Elves remaining in Middle-earth. Bearer of Nenya, the Ring of Water.","tags":["Elf","Lady","Ring-bearer"],"isAlive":true,"relationshipIds":["rel_celeborn_galadriel"],"portraitImageId":"3l_LjtzwVJJ5giIkwsa7-","updatedAt":1775160325915,"color":null,"createdAt":1700000000000},{"id":"char_gildor","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Gildor Inglorion","portra