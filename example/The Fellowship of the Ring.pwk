6,"color":null},{"id":"char_sam_gamgee","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Samwise Gamgee","portraitImageId":"w9bUT3rKVZ8ItCTeFK5OI","aliases":["Sam"],"description":"Frodo's loyal gardener and friend.","tags":["Hobbit","Gardener"],"relationshipIds":["rel_fs"],"isAlive":true,"createdAt":1741000000000,"updatedAt":1775101565396,"color":null},{"id":"char_sauron","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Sauron","portraitImageId":"8Y_2hntMIgLZwxTe_HAtb","aliases":["The Dark Lord","The Necromancer"],"description":"The creator of the One Ring, gathering his power in Mordor.","tags":["Maia","Dark Lord"],"relationshipIds":["rel_sauron_gollum"],"isAlive":true,"createdAt":1741000000000,"updatedAt":1775101629834,"color":null},{"id":"char_tom_bombadil","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Tom Bombadil","portraitImageId":"Um_gSChkqRXCvjboE21dG","aliases":["Iarwain Ben-adar"],"description":"A merry, mysterious, and immensely powerful being residing in the Old Forest.","tags":["Unknown"],"relationshipIds":["rel_frodo_tom"],"isAlive":true,"createdAt":1741000000000,"updatedAt":1775102277963,"color":null},{"id":"char_watcher","worldId":"aX-7torL9Na4l4UvyLWIP","name":"The Watcher in the Water","aliases":["The Watcher"],"description":"A mysterious, many-tentacled creature lurking in the stagnant pool before the West-gate of Moria.","tags":["Monster","Enemy"],"isAlive":true,"relationshipIds":[],"portraitImageId":"MA4OtrG5WAR_tCXnuqiLU","updatedAt":1775159205391,"color":null,"createdAt":1700000000000},{"id":"char_witch_king","worldId":"aX-7torL9Na4l4UvyLWIP","name":"The Witch-king of Angmar","aliases":["Lord of the Nazgûl","Black Captain"],"description":"The leader of the Ringwraiths and Sauron's most powerful servant.","tags":["Nazgûl","Enemy"],"isAlive":true,"relationshipIds":["rel_frodo_witchking"],"portraitImageId":"7A2vfM5_liTMdrWNCwOsP","updatedAt":1775155213786,"color":null,"createdAt":1700000000000},{"id":"ouYAUjn2Tk2wlv3NQwsSX","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Bilbo Baggins","aliases":[],"description":"Original bearer of the One Ring","portraitImageId":"FxBnVNlUS72huju8Rruso","tags":[],"isAlive":true,"createdAt":1775082744492,"updatedAt":1775083637425,"relationshipIds":["rel_bf","rel_bg","rel_bl"],"color":null},{"id":"rPOFbCqkPNTgsoIN8_tX6","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Gandalf the Grey","aliases":[],"description":"Gandalf the Grey is a wise, compassionate, and powerful Maiar spirit (Istari wizard) sent to Middle-earth to guide its peoples against Sauron.\nAppearing as an elderly man with a grey beard, pointy hat, and staff, he acts as a mentor, \"Grey Wanderer,\" and fiery combatant, fostering hope rather than relying solely on magical power.","portraitImageId":"utBmPle9EMGDF1MN6BuD2","tags":[],"isAlive":false,"createdAt":1775083195321,"updatedAt":1775083326500,"relationshipIds":["rel_bg"],"color":null},{"id":"yCsufFPoyoKIj5aOKzvYu","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Frodo Baggins","aliases":[],"description":"Frodo Baggins is a Hobbit of the Shire and the primary protagonist of J.R.R.\nTolkien’s The Lord of the Rings. As the Ring-bearer, he shows immense courage, resilience, and compassion, tasked with carrying the One Ring to Mordor to destroy it.\nHe is portrayed as wise, kind-hearted, and thoughtful, though he is heavily burdened and physically/emotionally scarred by the journey.","portraitImageId":"plMi9iOxFgsM2PNGu5wlK","tags":[],"isAlive":true,"createdAt":1775083048541,"updatedAt":1775083520423,"relationshipIds":["rel_bf","rel_fs","kaZwtj9r0hnHEWa411gOL","rel_frodo_pippin","rel_frodo_blackrider","rel_frodo_gildor","rel_frodo_merry","rel_frodo_maggot","rel_frodo_fatty","rel_frodo_tom","rel_frodo_willow","rel_frodo_strider","rel_frodo_barliman"],"color":null}],"items":[{"id":"fvZm5b3dn4KEyHShSofda","imageId":"ykuGV8vJZQkmrB1m2_lGQ","worldId":"aX-7torL9Na4l4UvyLWIP","name":"The One Ring","description":"One ring to rule them all","iconType":"","tags":[]},{"id":"item_anduril","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Andúril","description":"The Flame of the West. Forged in Rivendell from the shards of Narsil for Aragorn.","iconType":"weapon","tags":["Weapon","Sword","Legendary"],"imageId":"JbYUPF6bwaN1lQvGvBIQP"},{"id":"item_athelas","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Athelas","description":"Also known as Kingsfoil, a healing herb brought to Middle-earth by the Men of Westernesse. Strider uses it to combat the effects of the Morgul-wound.","iconType":"consumable","tags":["Herb","Healing"],"imageId":"rVKYAwXF9I5u0515BweOd"},{"id":"item_barrow_blades","imageId":"FLUtlSCAjx0Z7lpooYK5j","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Barrow-blades","description":"Ancient daggers forged by the Men of Westernesse.","iconType":"weapon","tags":["Weapon","Dagger"]},{"id":"item_bow_galadhrim","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Bow of the Galadhrim","description":"A stout bow strung with Elf-hair, longer and stronger than those of Mirkwood.","iconType":"weapon","tags":["Weapon","Bow","Elven"],"imageId":"w_UYl6tvnlxK8CHLXwvp4"},{"id":"item_elessar","worldId":"aX-7torL9Na4l4UvyLWIP","name":"The Elfstone","description":"A great green stone set in a silver eagle brooch, given to Aragorn as a token of hope.","iconType":"artifact","tags":["Jewelry","Elven"],"imageId":"P1Rwg9Cgk0IAYxH-jm8PJ"},{"id":"item_elven_cloaks","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Elven Cloak","description":"A grey-green cloak fastened with a leaf-brooch of Lórien that helps camouflage the wearer from unfriendly eyes.","iconType":"armor","tags":["Clothing","Elven","Stealth"],"imageId":"7TBanZlcWIyttjeGRiAYh"},{"id":"item_elven_rope","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Hithlain Rope","description":"Light, strong, grey-silvery rope made by the Elves of Lórien.","iconType":"tool","tags":["Tool","Elven"],"imageId":"-8NmjfktBL7DYGDGh09dp"},{"id":"item_galadriel_hair","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Galadriel's Hair","description":"Three strands of golden hair from the Lady of the Wood, given to Gimli at his request.","iconType":"artifact","tags":["Relic","Gift"],"imageId":"3bgpvOYipJIvS73dDpJpD"},{"id":"item_gandalf_letter","imageId":"zcOuPCim2AdgD9SrAm4yy","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Gandalf's Letter","description":"A delayed letter from Gandalf urging Frodo to leave the Shire quickly and confirming Strider's true identity.","iconType":"document","tags":["Document","Letter"]},{"id":"item_lembas","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Lembas","description":"Elven waybread. Extremely nutritious; one wafer can sustain a traveler for a day of hard labor.","iconType":"consumable","tags":["Food","Elven"],"imageId":"WvHckGrBAchJ65_g4ObVA"},{"id":"item_mirror_galadriel","worldId":"aX-7torL9Na4l4UvyLWIP","name":"The Mirror of Galadriel","description":"A silver basin on a low pedestal, filled with water from a nearby stream. It shows visions of the past, present, and possible futures.","iconType":"artifact","tags":["Magic","Artifact"],"imageId":"UWaCKGC4KN7VQc8t_FVec"},{"id":"item_mithril_shirt","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Mithril Coat","description":"A lightweight but incredibly strong chainmail shirt made of pure Mithril. Given to Frodo by Bilbo.","iconType":"armor","tags":["Armor","Dwarven","Legendary"],"imageId":"wA5wJpJQ7kWPA2y4GwHDu"},{"id":"item_morgul_blade","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Morgul-blade","description":"A poisoned magical dagger wielded by the Nazgûl. A piece of the blade breaks off in the victim to pull them into the wraith world.","iconType":"weapon","tags":["Weapon","Cursed"],"imageId":"D2_v_tiib4flXNFTZnnMr"},{"id":"item_narsil","imageId":"nscbbpOsj5vA3aZ4nmPIo","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Narsil (Broken)","description":"The legendary sword of Elendil, broken during the battle with Sauron.","iconType":"weapon","tags":["Weapon","Sword","Relic"]},{"id":"item_nenya","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Nenya","description":"The Ring of Water, one of the Three Elven Rings of Power. It is made of Mithril and set with a stone of adamant. Wielded by Galadriel to protect and preserve Lothlórien.","iconType":"ring","tags":["Ring of Power","Elven","Legendary"],"imageId":"bbHqZSGJ_HIgjWmSN20aK"},{"id":"item_phial_galadriel","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Phial of Galadriel","description":"A crystal phial containing the light of Eärendil's star caught in the waters of Galadriel's fountain.","iconType":"artifact","tags":["Magic","Light"],"imageId":"GtFn_k_8ECJ1xEVirx_wg"},{"id":"item_sting","worldId":"aX-7torL9Na4l4UvyLWIP","name":"Sting","description":"An ancient Elven dagger that glows blue in the presence of Orcs. Given to Frodo by Bilbo.","iconType":"weapon","tags":["Weapon","Dagger","Elven"],"imageId":"aR0olOyPg1U6YTh3OJ1_I"}],"characterSnapshots":[{"id":"0103135c-20cd-4860-955e-4af5f22e861a","worldId":"aX-7torL9Na4l4UvyLWIP","characterId":"char_aragorn_strider","eventId":"c1d42be8-963d-4c81-b5ea-1b9da7223b2c","isAlive":true,"currentLocationMarkerId":"8U_bY2J4d10RE9KgchIaN","currentMapLayerId":"kVCDnF0B7uPhB04BOUsp1","inventoryItemIds":[],"inventoryNotes":"","statusNotes":"Explaining the peril the Hobbits are in, revealing his knowledge of the Black Riders.","travelModeId":null,"createdAt":1775594002123,"updatedAt":1775594002123,"sortKey":100000},{"id":"01b2c4d9-df77-4b66-bc11-fb328325cd69","worldId":"aX-7torL9Na4l4UvyLWIP","characterId":"char_black_rider_1","eventId":"f5b66d74-c3a9-40e8-963a-eb8b2f934441","isAlive":true,"currentLocationMarkerId":"mZ2AOteCjotruUEgjApqG","currentMapLayerId":"VzpwzK_Qa2opnNiOBwiU2","inventoryItemIds":[],"inventoryNotes":"","statusNotes":"Has crossed into the Shire, asking locals about a Hobbit named Baggins.","travelModeId":null,"createdAt":1775592885453,"updatedAt":1775592885453,"sortKey":30000},{"id":"0a5c8d2b-1f9e-436c-b7e4-5a1d8f2c9e3b","worldId":"aX-7torL9Na4l4UvyLWIP","characterId":"char_legolas","eventId":"6d9a42f1-c8b5-41a3-97e2-1a48f2d5b6c9","isAlive":true,"currentLocationMarkerId":